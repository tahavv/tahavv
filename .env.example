# ✉️ Email Configuration Variables
# These are required for the contact form API endpoint to function.
# Configure these identically in Railway / GitHub Actions secrets for production.

# The outgoing SMTP server of your email provider (e.g., smtp.gmail.com or smtp-mail.outlook.com)
SMTP_HOST=smtp.example.com

# The port used by your SMTP provider, usually 465 (SSL) or 587 (TLS)
SMTP_PORT=587

# The email address you use to log into your SMTP provider
SMTP_USER=your-email@example.com

# The password, app-specific password, or API key for your SMTP service
SMTP_PASS=your-secure-app-password

# The email address where you want to receive the contact form submissions
RECEIVER_EMAIL=your-receiving-email@example.com

# Optional: Mailtrap API fallback if SMTP fails
# Get token from Mailtrap account settings
MAILTRAP_TOKEN=your-mailtrap-api-token
# Optional: Mailtrap API host override (defaults to https://send.api.mailtrap.io)
MAILTRAP_HOST=https://send.api.mailtrap.io

# Optional: set to false for production sending, true for Mailtrap testing inbox mode
MAILTRAP_SANDBOX=true

# Optional: required when MAILTRAP_SANDBOX=true
MAILTRAP_TEST_INBOX_ID=4020625
